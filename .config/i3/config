# AUTOSTART #############################################
exec_always --no-startup-id killall -q picom; sleep 1; picom &
#exec --no-startup-id exec kitty -e killall plank
exec_always --no-startup-id xsetroot -cursor_name left_ptr
exec_always --no-startup-id xrdb -merge ~/.Xresources
exec --no-startup-id /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1
exec_always --no-startup-id ~/.config/i3/smart_monitor.sh
exec_always --no-startup-id easyeffects --gapplication-service &
exec_always --no-startup-id sleep 5 && killall xfce4-power-manager gsd-power
# Auto-switch split orientation
exec_always --no-startup-id autotiling
exec --no-startup-id xset s off
exec --no-startup-id xset -dpms
exec --no-startup-id /usr/bin/gnome-keyring-daemon --start --components=pkcs11,secrets,ssh
# Restore last wallpaper & colors on login
exec --no-startup-id ~/.config/i3/wallpaper-switcher.sh -a "$(cat ~/.config/.current_wallpaper)"
# Activate Linux Watermark
exec_always --no-startup-id eww -c ~/.config/eww/activate-linux open activate-linux

