#!/bin/bash

# Auto-detect the active wireless interface
iface=$(iw dev | awk '$1=="Interface"{print $2}' | head -n 1)

status=$(nmcli g | grep -oE "disconnected")
essid=$(nmcli c | grep "$iface" | awk '{print ($1)}')

if [ $status ] ; then
    icon="Óáö"
    text=""
    col="#575268"

else
    icon="ÓÜļ"
    text="${essid}"
    col="#a1bdce"
fi



if [[ "$1" == "--COL" ]]; then
    echo $col	
elif [[ "$1" == "--ESSID" ]]; then
	echo $text
elif [[ "$1" == "--ICON" ]]; then
	echo $icon
fi

